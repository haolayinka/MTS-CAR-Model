beta1 <- 2
beta2 <- -3
beta3 <- 1.5
Y <- beta0 + beta1*X + beta2*X^2 + beta3*X^3 + eps
library(leaps)
install.packages("leaps")
library(leaps)
dat <- data.frame(
Y = Y,
X1 = X,
X2 = X^2,
X3 = X^3,
X4 = X^4,
X5 = X^5,
X6 = X^6,
X7 = X^7,
X8 = X^8,
X9 = X^9,
X10 = X^10
)
best_fit <- regsubsets(Y ~ ., data = dat, nvmax = 10, method = "exhaustive")
best_sum <- summary(best_fit)
# Which model size is best under each criterion?
cp_best_size <- which.min(best_sum$cp)
bic_best_size <- which.min(best_sum$bic)
adjr2_best_size <- which.max(best_sum$adjr2)
cp_best_size
bic_best_size
adjr2_best_size
# Coefficients of the best models
coef(best_fit, cp_best_size)
coef(best_fit, bic_best_size)
coef(best_fit, adjr2_best_size)
# Plot
par(mfrow = c(1, 3))
plot(best_sum$cp, xlab = "Number of predictors", ylab = "Cp", type = "b")
points(cp_best_size, best_sum$cp[cp_best_size], col = "red", pch = 19, cex = 1.5)
plot(best_sum$bic, xlab = "Number of predictors", ylab = "BIC", type = "b")
points(bic_best_size, best_sum$bic[bic_best_size], col = "red", pch = 19, cex = 1.5)
plot(best_sum$adjr2, xlab = "Number of predictors", ylab = "Adjusted R^2", type = "b")
points(adjr2_best_size, best_sum$adjr2[adjr2_best_size], col = "red", pch = 19, cex = 1.5)
forward_fit <- regsubsets(Y ~ ., data = dat, nvmax = 10, method = "forward")
backward_fit <- regsubsets(Y ~ ., data = dat, nvmax = 10, method = "backward")
forward_sum <- summary(forward_fit)
backward_sum <- summary(backward_fit)
# Forward: best model sizes
f_cp_best <- which.min(forward_sum$cp)
f_bic_best <- which.min(forward_sum$bic)
f_adjr2_best <- which.max(forward_sum$adjr2)
# Backward: best model sizes
b_cp_best <- which.min(backward_sum$cp)
b_bic_best <- which.min(backward_sum$bic)
b_adjr2_best <- which.max(backward_sum$adjr2)
# Coefficients
coef(forward_fit, f_cp_best)
coef(forward_fit, f_bic_best)
coef(forward_fit, f_adjr2_best)
coef(backward_fit, b_cp_best)
coef(backward_fit, b_bic_best)
coef(backward_fit, b_adjr2_best)
# Plot
par(mfrow = c(2, 3))
plot(forward_sum$cp, xlab = "Number of predictors", ylab = "Cp", type = "b",
main = "Forward Cp")
points(f_cp_best, forward_sum$cp[f_cp_best], col = "red", pch = 19)
plot(forward_sum$bic, xlab = "Number of predictors", ylab = "BIC", type = "b",
main = "Forward BIC")
points(f_bic_best, forward_sum$bic[f_bic_best], col = "red", pch = 19)
plot(forward_sum$adjr2, xlab = "Number of predictors", ylab = "Adjusted R^2", type = "b",
main = "Forward Adjusted R^2")
points(f_adjr2_best, forward_sum$adjr2[f_adjr2_best], col = "red", pch = 19)
plot(backward_sum$cp, xlab = "Number of predictors", ylab = "Cp", type = "b",
main = "Backward Cp")
points(b_cp_best, backward_sum$cp[b_cp_best], col = "red", pch = 19)
plot(backward_sum$bic, xlab = "Number of predictors", ylab = "BIC", type = "b",
main = "Backward BIC")
points(b_bic_best, backward_sum$bic[b_bic_best], col = "red", pch = 19)
plot(backward_sum$adjr2, xlab = "Number of predictors", ylab = "Adjusted R^2", type = "b",
main = "Backward Adjusted R^2")
points(b_adjr2_best, backward_sum$adjr2[b_adjr2_best], col = "red", pch = 19)
library(glmnet)
install.packages("glmnet")
library(glmnet)
x_mat <- model.matrix(Y ~ ., data = dat)[, -1]   # remove intercept column
y_vec <- dat$Y
set.seed(15)
cv_lasso <- cv.glmnet(x_mat, y_vec, alpha = 1)
# Plot CV error curve
plot(cv_lasso)
# Best lambda values
cv_lasso$lambda.min
cv_lasso$lambda.1se
# Coefficients at lambda.min
coef(cv_lasso, s = "lambda.min")
# Coefficients at lambda.1se
coef(cv_lasso, s = "lambda.1se")
set.seed(15)
X <- rnorm(n)
eps <- rnorm(n)
beta0 <- 1
beta7 <- 2
Y <- beta0 + beta7*X^7 + eps
dat2 <- data.frame(
Y = Y,
X1 = X,
X2 = X^2,
X3 = X^3,
X4 = X^4,
X5 = X^5,
X6 = X^6,
X7 = X^7,
X8 = X^8,
X9 = X^9,
X10 = X^10
)
# Best subset selection
best_fit2 <- regsubsets(Y ~ ., data = dat2, nvmax = 10, method = "exhaustive")
best_sum2 <- summary(best_fit2)
cp_best_size2 <- which.min(best_sum2$cp)
bic_best_size2 <- which.min(best_sum2$bic)
adjr2_best_size2 <- which.max(best_sum2$adjr2)
cp_best_size2
bic_best_size2
adjr2_best_size2
coef(best_fit2, cp_best_size2)
coef(best_fit2, bic_best_size2)
coef(best_fit2, adjr2_best_size2)
# Plots for best subset selection
par(mfrow = c(1, 3))
plot(best_sum2$cp, xlab = "Number of predictors", ylab = "Cp", type = "b")
points(cp_best_size2, best_sum2$cp[cp_best_size2], col = "red", pch = 19, cex = 1.5)
plot(best_sum2$bic, xlab = "Number of predictors", ylab = "BIC", type = "b")
points(bic_best_size2, best_sum2$bic[bic_best_size2], col = "red", pch = 19, cex = 1.5)
plot(best_sum2$adjr2, xlab = "Number of predictors", ylab = "Adjusted R^2", type = "b")
points(adjr2_best_size2, best_sum2$adjr2[adjr2_best_size2], col = "red", pch = 19, cex = 1.5)
# Lasso
x_mat2 <- model.matrix(Y ~ ., data = dat2)[, -1]
y_vec2 <- dat2$Y
set.seed(15)
cv_lasso2 <- cv.glmnet(x_mat2, y_vec2, alpha = 1)
plot(cv_lasso2)
cv_lasso2$lambda.min
cv_lasso2$lambda.1se
coef(cv_lasso2, s = "lambda.min")
coef(cv_lasso2, s = "lambda.1se")
